{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "outputDirectory": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "^/(static|asset-manifest\\.json|favicon\\.ico|manifest\\.json|robots\\.txt|logo.*\\.png)(/.*)?$",
      "dest": "frontend/$1$2"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ]
}
